# SoT — пример настроек для .env
# Скопируй в `code/.env` и подставь свои значения.
# Реальный `.env` не коммитится (см. корневой .gitignore) — особенно ради API-ключей.

# === Эксперимент ===
K=2
T_MAX=4
N=16
RANDOM_SEED=0

# === LLM (общее) ===
# Тип бэкенда: hf | openai | gemini | mock
LLM_TYPE=hf
LLM_MAX_NEW_TOKENS=16

# === HuggingFace (если LLM_TYPE=hf) ===
HF_MODEL_NAME=gpt2
HF_DEVICE=cuda

# === OpenAI (если LLM_TYPE=openai) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Gemini (если LLM_TYPE=gemini) ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# === Задачи ===
TASK_TYPE=word_problem
TASK_NUM_OPERANDS=3
TASK_MAX_VALUE=9

# === Shapley ===
SHAPLEY_ALGORITHM=perm_mc
SHAPLEY_M=32
SHAPLEY_STEP_PENALTY=0.05

# === Тренировка ===
TRAINING_BUFFER_SIZE=1024
TRAINING_BATCH_SIZE=16
TRAINING_TOTAL_ENV_STEPS=10000
